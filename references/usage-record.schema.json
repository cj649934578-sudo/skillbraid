{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Skill Route Usage Records",
  "type": "object",
  "required": [
    "version",
    "records"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "date",
          "request_summary",
          "scenario",
          "route_name",
          "chain",
          "result_status",
          "signals"
        ],
        "properties": {
          "date": {
            "type": "string"
          },
          "request_summary": {
            "type": "string"
          },
          "scenario": {
            "type": "string"
          },
          "route_name": {
            "type": "string"
          },
          "chain": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "result_status": {
            "type": "string",
            "enum": [
              "success",
              "partial",
              "blocked",
              "skipped"
            ]
          },
          "signals": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "new_scenario",
                "temporary_skill_added",
                "route_conflict",
                "missing_skill",
                "user_overrode_route",
                "candidate_for_project_rule",
                "candidate_for_global_preference"
              ]
            }
          },
          "note": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
